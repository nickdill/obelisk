OBELISK_AUTHORIZED_KEY=

# Registry authentication (ghcr.io, Docker Hub, etc.)
REGISTRY_HOST=ghcr.io
REGISTRY_USER=
REGISTRY_TOKEN=

# AWS ECR (alternative to REGISTRY_HOST)
# AWS_ACCOUNT=
# AWS_REGION=
# REGISTRY=${AWS_ACCOUNT}.dkr.ecr.us-east-2.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

OBELISK_ENV=local

OBELISK_SSL=false
OBELISK_SSL_EMAIL=
OBELISK_SSL_STAGING=0

